name        : asylum:system:mailbox:1.0.0
description : mailbox Module

#=========================================
generate:
#=========================================

  #---------------------------------------
  gen_csr:
  #---------------------------------------
    generator : regtool
    parameters:
      file         : hdl/csr/mailbox.hjson
      name         : mailbox
      copy         : hdl/csr
      logical_name : asylum

#=========================================
filesets:
#=========================================

  #---------------------------------------
  hdl:
  #---------------------------------------
    files        :
      - hdl/mailbox_pkg.vhd
      - hdl/sbi_mailbox.vhd
    file_type    : vhdlSource
    logical_name : asylum
    depend       :
      - asylum:utils:generators
      - asylum:utils:pkg
      - asylum:target:techmap

#=========================================
targets:
#=========================================

  #---------------------------------------
  default: &default
  #---------------------------------------
    description     : Default Target
    filesets        :
      - hdl
    toplevel        : mailbox
    default_tool    : ghdl
    generate        :
      - gen_csr


# Next lines is a pragma, don't modify
#<PROVIDER_BEGIN>
provider  :
  name    : github
  user    : deuskane
  repo    : asylum-system-mailbox
  version : asylum-system-mailbox-1.0.0
 #version : 41cd4fc15f818b751ff498cb9c94333b8ec751e7
#<PROVIDER_END>
