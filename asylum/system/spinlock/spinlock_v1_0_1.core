name        : asylum:system:spinlock:1.0.1
description : spinlock Module

#=========================================
generate:
#=========================================

  #---------------------------------------
  gen_csr:
  #---------------------------------------
    generator : regtool
    parameters:
      file         : hdl/csr/spinlock.hjson
      name         : spinlock
      copy         : hdl/csr
      logical_name : asylum

#=========================================
filesets:
#=========================================

  #---------------------------------------
  hdl:
  #---------------------------------------
    files        :
      - hdl/spinlock_pkg.vhd
      - hdl/sbi_spinlock.vhd
    file_type    : vhdlSource
    logical_name : asylum
    depend       :
      - asylum:utils:generators
      - asylum:utils:pkg
      - asylum:target:techmap

#=========================================
targets:
#=========================================

  #---------------------------------------
  default: &default
  #---------------------------------------
    description     : Default Target
    filesets        :
      - hdl
    toplevel        : spinlock
    default_tool    : ghdl
    generate        :
      - gen_csr


# Next lines is a pragma, don't modify
#<PROVIDER_BEGIN>
provider  :
  name    : github
  user    : deuskane
  repo    : asylum-system-spinlock
  version : asylum-system-spinlock-1.0.1
 #version : 3a8c24a950da2cdb086eba143cfa7bf9e3d9f8e4
#<PROVIDER_END>
